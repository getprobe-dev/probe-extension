{
  "manifest_version": 3,
  "name": "PRobe",
  "description": "AI review companion for GitHub PRs",
  "version": "1.0.0",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["src/content/index.tsx"],
      "css": ["src/styles/content.css"]
    }
  ],
  "permissions": ["storage", "activeTab", "declarativeNetRequest"],
  "host_permissions": [
    "https://github.com/*/*/pull/*",
    "https://*.githubusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.png"],
      "matches": ["https://github.com/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
