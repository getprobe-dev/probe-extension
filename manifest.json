{
  "manifest_version": 3,
  "name": "PRobe",
  "description": "PRobe — chat with any GitHub pull request.",
  "version": "0.1.0",
  "icons": {
    "16": "dark-mode/icon-16.png",
    "48": "dark-mode/icon-48.png",
    "128": "dark-mode/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "dark-mode/icon-16.png",
      "48": "dark-mode/icon-48.png",
      "128": "dark-mode/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["src/content/index.tsx"],
      "css": ["src/styles/content.css"]
    }
  ],
  "permissions": ["storage", "activeTab", "declarativeNetRequest"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://*.githubusercontent.com/*",
    "https://*.workers.dev/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dark-mode/*.png", "light-mode/*.png"],
      "matches": ["https://github.com/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
